POST http://127.0.0.1:8000/api/docs
Content-Type: application/json

{
  "title": "示例文档",
  "content": "RAG 是检索增强生成。它通常先检索相关片段，再让大模型基于上下文生成回答。",
  "tags": ["demo"],
  "owner": "user123"
}

